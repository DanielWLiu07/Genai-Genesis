RENDER_SERVICE_URL=http://localhost:8002
API_SERVICE_URL=http://localhost:8000

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Kling 3.0 (video/image generation)
KLING_API_KEY=your-kling-access-key
KLING_API_SECRET=your-kling-secret-key
